generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  openid            String    @unique
  nickname          String?
  avatarUrl         String?
  height            Float?
  targetWeight      Float?
  goal              Goal?
  level             Level     @default(BEGINNER)
  equipment         Equipment @default(GYM)
  weeklyTrainingDays Int      @default(3)
  currentPhase      Phase     @default(MAINTAIN)
  fitnessDuration   FitnessDuration?
  hasCompletedOnboarding Boolean @default(false)
  role              UserRole  @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  weightRecords      WeightRecord[]
  measurementRecords MeasurementRecord[]
  progressPhotos     ProgressPhoto[]
  supplementRecords  SupplementRecord[]
  exercises          Exercise[]
  recoveryStatuses   RecoveryStatus[]
  logEntries         LogEntry[]
  trainingLogs      TrainingLog[]
  workoutPlans       WorkoutPlan[]
  chatMessages       ChatMessage[]
  chatSessions       ChatSession[]
  pushQueues         PushQueue[]
  pushRecords        PushRecord[]
  achievements       Achievement[]
  articles           Article[]
  contributions      UserContribution[]
}

model WeightRecord {
  id         String   @id @default(uuid())
  userId     String
  weight     Float
  recordedAt DateTime @db.Date
  note       String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, recordedAt])
}

model MeasurementRecord {
  id          String   @id @default(uuid())
  userId      String
  waist       Float?
  hip         Float?
  chest       Float?
  leftArm     Float?
  rightArm    Float?
  leftThigh   Float?
  rightThigh  Float?
  leftCalf    Float?
  rightCalf   Float?
  bodyFat     Float?
  recordedAt  DateTime @db.Date
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SupplementRecord {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  supplement  String
  dosage      String?
  timing      String?
  note        String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, supplement])
}

model ProgressPhoto {
  id         String      @id @default(uuid())
  userId     String
  photoUrl   String
  angle      PhotoAngle
  recordedAt DateTime    @db.Date
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum Goal {
  LOSE_FAT
  GAIN_MUSCLE
  BODY_SHAPE
  IMPROVE_FITNESS
}

enum UserRole {
  USER
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Equipment {
  GYM
  DUMBBELL
  BODYWEIGHT
}

enum Phase {
  CUT
  BULK
  MAINTAIN
}

enum FitnessDuration {
  LESS_THAN_3M    // 3个月以下
  THREE_TO_6M     // 3-6个月
  SIX_TO_12M      // 6-12个月
  OVER_1Y         // 1年以上
}

enum PhotoAngle {
  FRONT
  SIDE
  BACK
}

model RecoveryStatus {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @db.Date
  score         Int?     // 0-100, null means not yet computed
  sleepHours    Float?   // hours of sleep
  muscleStatus  Json?    // Record<string, number> muscle -> recovery score
  recommendation String? // REST | LIGHT | TRAIN
  soreness      Int      @default(0) // 0-10 scale
  fatigue       Int      @default(0) // 0-10 scale
  sleepQuality  Int      @default(0) // 0-10 scale
  notes         String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model TrainingLog {
  id            String    @id @default(uuid())
  userId        String
  planId        String?
  planDayId     String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  duration      Int?      // seconds
  totalVolume   Float?    // kg, sum of weight * reps for non-warmup sets
  status        LogStatus @default(IN_PROGRESS)

  user      User      @relation(fields: [userId], references: [id])
  logEntries LogEntry[]
}

enum LogStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model LogEntry {
  id            String    @id @default(uuid())
  userId        String
  logId         String
  exerciseId    String
  exerciseName  String
  setNumber     Int
  weight        Float
  reps          Int
  isWarmup      Boolean   @default(false)
  e1rm          Float?    // estimated 1RM (Epley formula)
  muscleVolumes Json       // { "chest": 480, "triceps": 240, ... } 主肌群×1.0, 辅肌群×0.5
  completedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id])
  trainingLog TrainingLog @relation(fields: [logId], references: [id])
  exercise   Exercise    @relation(fields: [exerciseId], references: [id])
}

model PlanDay {
  id        String   @id @default(uuid())
  planId    String
  dayOfWeek Int      // 1-7
  dayType   String   // e.g. "胸部+三头", "休息"
  notes     String?
  createdAt DateTime @default(now())

  plan             WorkoutPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  plannedExercises PlannedExercise[]
}

model PlannedExercise {
  id          String   @id @default(uuid())
  planId      String
  planDayId   String
  exerciseId  String
  sets        Int
  reps        Int
  restSeconds Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  planDay      PlanDay                    @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  exercise     Exercise                   @relation(fields: [exerciseId], references: [id])
  replacements PlanExerciseReplacement[]
}

// 动作替换记录
model PlanExerciseReplacement {
  id                  String   @id @default(uuid())
  plannedExerciseId   String
  originalExerciseId  String
  newExerciseId       String
  reason             String   // 替换原因: not_interested | no_equipment | dont_know_how | other
  createdAt          DateTime @default(now())

  plannedExercise   PlannedExercise   @relation(fields: [plannedExerciseId], references: [id], onDelete: Cascade)
  originalExercise  Exercise          @relation("OriginalExercise", fields: [originalExerciseId], references: [id])
  newExercise       Exercise          @relation("NewExercise", fields: [newExerciseId], references: [id])

  @@index([plannedExerciseId])
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model WorkoutPlan {
  id          String    @id @default(uuid())
  userId      String
  name        String
  goal        Goal?     // goal at time of creation
  weeks       Int       @default(4)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  status      PlanStatus @default(ACTIVE)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  planDays     PlanDay[]
}

model Exercise {
  id            String   @id @default(uuid())
  name          String
  nameEn        String?
  category      ExerciseCategory
  equipment     Equipment
  primaryMuscles Json
  secondaryMuscles Json
  instructions  String?  @db.VarChar(2000)
  instructionsZh String?  @db.Text
  commonMistakes String?  @db.Text
  warnings      String?  @db.Text
  videoUrl      String?
  imageUrls     String?  @db.Text
  isCustom      Boolean  @default(false)
  isFavorite    Boolean  @default(false)
  userId        String?
  createdAt     DateTime  @default(now())

  user                  User?                     @relation(fields: [userId], references: [id])
  logEntries            LogEntry[]
  plannedExercises       PlannedExercise[]
  exerciseMuscles       ExerciseMuscle[]
  originalReplacements   PlanExerciseReplacement[] @relation("OriginalExercise")
  newReplacements        PlanExerciseReplacement[] @relation("NewExercise")
}

enum ExerciseCategory {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
  CARDIO
}

enum MuscleCategory {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
}

enum MuscleRole {
  PRIMARY
  SECONDARY
}

model Muscle {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  aliases       Json
  category      MuscleCategory
  parentCode    String?
  recoveryHours Int           @default(48)
  createdAt     DateTime      @default(now())

  parent            Muscle?          @relation("MuscleHierarchy", fields: [parentCode], references: [code])
  children          Muscle[]         @relation("MuscleHierarchy")
  exerciseMuscles   ExerciseMuscle[]
}

model ExerciseMuscle {
  id          String     @id @default(uuid())
  exerciseId  String
  muscleId    String
  role        MuscleRole
  ratio       Float      @default(1.0)
  createdAt   DateTime   @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id])

  @@unique([exerciseId, muscleId])
}

// ============================================
// Phase 3: AI Chat 相关模型
// ============================================

model ChatMessage {
  id          String   @id @default(uuid())
  userId      String
  role        String   // "user" | "ai"
  type        String   // "text" | "card"
  cardType    String?  // card 时对应的 cardType
  content     String?  @db.Text  // text 消息内容
  cardData    Json?    // card 消息的 data 字段
  actions     Json?    // card 消息的 actions 数组
  planId      String?  // 关联的训练计划
  sessionId   String? // 关联的会话 ID
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  session     ChatSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, createdAt])
}

model ChatSession {
  id          String   @id @default(uuid())
  userId      String
  status      SessionStatus @default(ACTIVE)
  context     Json     // 存储追问上下文
  pendingIntent String? // 待完成的意图
  missingFields Json?  // 缺失的字段列表
  clarificationHistory Json? // 追问历史
  retryCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  messages    ChatMessage[]

  @@index([userId, status])
  @@index([userId, updatedAt])
}

enum SessionStatus {
  ACTIVE              // 正常对话
  AWAITING_CLARIFICATION  // 等待用户澄清
  COMPLETED           // 已完成（已提取足够信息）
  EXPIRED            // 已过期（超时或用户取消）
}

model PushQueue {
  id          String   @id @default(uuid())
  userId      String
  cardType    String   // 推送的卡片类型
  data        Json     // 卡片 data
  actions     Json?    // 卡片 actions
  triggerAt   DateTime // 触发时间
  sentAt      DateTime? // 已发送时间（null=待发送）
  expiresAt   DateTime // 过期时间
  priority    Int      @default(0) // 优先级，数值越大优先级越高
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, sentAt, triggerAt])
}

model PushRecord {
  id          String   @id @default(uuid())
  userId      String
  cardType    String
  sentAt      DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, cardType, sentAt])
}

// ============================================
// 成就系统
// ============================================

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  type        String   // 'first_training', 'week_streak', 'first_pr', etc.
  name        String
  description String?
  icon        String?  // 成就图标
  unlockedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

// ============================================
// 运营端管理员日志
// ============================================

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // "UPDATE_USER", "DELETE_EXERCISE"
  target    String   // 资源 ID
  detail    Json?    // 变更详情
  createdAt DateTime @default(now())
}

// ============================================
// 知识库
// ============================================

enum ArticleType {
  KNOWLEDGE   // 健身百科
  FAQ         // 常见问题
  COURSE      // 课程内容
}

enum ArticleStatus {
  DRAFT       // 草稿
  PENDING     // 待审核（UGC 提交）
  PUBLISHED   // 已发布
  REJECTED    // 已拒绝
}

enum ContributionType {
  CREATE      // 新建文章
  EDIT        // 编辑建议
}

enum ContributionStatus {
  PENDING     // 待审核
  APPROVED    // 已采纳
  REJECTED    // 已拒绝
}

model ArticleCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String
  type      ArticleType
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles  Article[]
  parent    ArticleCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ArticleCategory[] @relation("CategoryHierarchy")
}

model Article {
  id          String   @id @default(uuid())
  title       String
  slug        String
  categoryId  String
  type        ArticleType
  content     String   @db.Text
  summary     String?
  coverImage  String?
  authorId    String?
  status      ArticleStatus @default(DRAFT)
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  isPinned    Boolean  @default(false)
  tags        Json     @default("[]")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category     ArticleCategory  @relation(fields: [categoryId], references: [id])
  author       User?            @relation(fields: [authorId], references: [id])
  versions     ArticleVersion[]
  contributions UserContribution[]
}

model ArticleVersion {
  id         String   @id @default(uuid())
  articleId  String
  version    Int
  title      String
  content    String   @db.Text
  changedBy  String
  changeNote String?
  createdAt  DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id])
}

model UserContribution {
  id          String   @id @default(uuid())
  userId      String
  articleId   String?
  type        ContributionType
  title       String?
  content     String   @db.Text
  status      ContributionStatus @default(PENDING)
  reviewerId  String?
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  article Article? @relation(fields: [articleId], references: [id])
}